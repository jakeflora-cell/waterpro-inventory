# WaterPro Inventory System — Environment Variables

# Server
PORT=3000

# Admin PIN (used for dashboard access — change this!)
ADMIN_PIN=1234

# Employee PINs (comma-separated: name:pin pairs)
# These are used for quick auth on the checkout screen
EMPLOYEE_PINS=Jake:0000,Cole:1111,AJ:2222

# Albi API
ALBI_API_KEY=your-albi-api-key-here
ALBI_BASE_URL=https://api.albiware.com/v5/Integrations

# Optional: Set to 'true' to skip Albi API calls during development
SKIP_ALBI=true
